# ============================================================
# TwoStrokeGPT  |  environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# ============================================================

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/twostroke

# ---- LLM endpoint (config.yaml reads env var *names* from here) ----
# Option A — Ollama local (default):
LLM_PROVIDER=local
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=local
LLM_MODEL=qwen3:8b

# Option B — vLLM or any OpenAI-compatible endpoint:
# LLM_PROVIDER=local
# LLM_BASE_URL=http://your-vllm-server:8000/v1
# LLM_API_KEY=your-key
# LLM_MODEL=meta-llama/Llama-3-8B-Instruct

# Option C — OpenAI:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Option D — Anthropic:
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# ---- Vision model (used for PDF diagram extraction) ----
# Defaults to LLM_MODEL if not set — only set this if you want
# a separate vision model (e.g. llama3.2 which supports images):
# LLM_VISION_MODEL=llama3.2:3b

# ---- Embeddings ----
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# ---- Ingestion ----
UPLOAD_DIR=./data/uploads
ENABLE_FIGURE_HANDLER=true

# ---- Optional: separate Anthropic/OpenAI keys ----
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
